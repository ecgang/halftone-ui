# Vercel's local link/build artifacts
.vercel

# Secrets, including whatever `vercel env pull` drops here. Ignore every .env
# variant and name the exceptions: .env.production and .env.development carry
# real values as often as .env.local does, so an allow-list is the safe shape.
.env
.env.*
!.env.example
!.env.template

# Dev-only harness deps (tools/). The site itself is static and has no build.
node_modules

# stray compiler scratch — a Mach-O a.out at root would otherwise ride a git add -A into the tree
a.out
*.out
