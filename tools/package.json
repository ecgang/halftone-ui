{
  "name": "halftone-ui-tools",
  "private": true,
  "type": "module",
  "description": "Dev-only harnesses. Deliberately NOT at the repo root: the site is static and Vercel detects its build from a root package.json, so adding one there would turn a static deploy into a Node build.",
  "scripts": {
    "golden:write": "node golden-frames.mjs --write",
    "golden:check": "node golden-frames.mjs --check",
    "golden:selftest": "node golden-frames.mjs --selftest",
    "verify": "node verify-all.mjs",
    "verify:quick": "node verify-all.mjs --no-golden"
  },
  "devDependencies": {
    "@vue/server-renderer": "^3.5.40",
    "esbuild": "^0.27.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vue": "^3.5.40"
  }
}
